# ── Brevo (e-posttjeneste) ─────────────────────────────────────────────────
# Opprett gratis konto på https://www.brevo.com og generer en API-nøkkel
# under Settings → API Keys
BREVO_API_KEY=your_brevo_api_key_here

# E-postadresse som mottar kontaktskjema-henvendelser
CONTACT_TO_EMAIL=hei@sykosofi.no

# ── TinaCMS (innholdsredigering) ───────────────────────────────────────────
# Opprett prosjekt på https://app.tina.io og fyll inn:
TINA_PUBLIC_CLIENT_ID=your_tina_client_id
TINA_TOKEN=your_tina_token

# Git-branch som TinaCMS skriver til (standard: main)
GITHUB_BRANCH=main
